# TripFlow 环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env

# --- MySQL（ECS 远程或本机，改 MYSQL_HOST 即可）---
MYSQL_HOST=8.134.34.169
MYSQL_PORT=3306
MYSQL_DATABASE=tripflow
MYSQL_USER=root
MYSQL_PASSWORD=你的密码

# --- 后端 tripflow-api ---
API_SERVER_PORT=8080

# --- Redis（主数据缓存）---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# --- 前端 tripflow-web 开发代理（Vite 仅 dev 使用）---
VITE_API_PROXY_TARGET=http://localhost:8080
